+/*
+ * pilotfaa.css
+ * All PilotFAA LMS styles, scoped with pf- prefix so they
+ * never conflict with the existing admin studio Tailwind/shadcn styles.
+ * Import in app/(lms)/layout.tsx only.
+ */
+
+@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
+
+/* ── Design tokens ─────────────────────────────────────────────────────────── */
+:root {
+  --pf-sky:        #EEF3FA;
+  --pf-sky-mid:    #E2EAF6;
+  --pf-white:      #FFFFFF;
+  --pf-ink:        #0F1F3A;
+  --pf-ink-mid:    #3A4E6B;
+  --pf-ink-dim:    #7A90AE;
+  --pf-rule:       #D0DCF0;
+  --pf-rule-light: #E8EFF9;
+  --pf-cobalt:     #1756C8;
+  --pf-cobalt-lt:  #EBF1FB;
+  --pf-cobalt-mid: #4A7AE0;
+  --pf-gold:       #C8860A;
+  --pf-gold-lt:    #FEF3DC;
+  --pf-green:      #127A48;
+  --pf-green-lt:   #E6F5EE;
+  --pf-red:        #C42B2B;
+  --pf-red-lt:     #FDEAEA;
+  --pf-amber:      #C86010;
+  --pf-amber-lt:   #FEF0E4;
+  --pf-radius-sm:  6px;
+  --pf-radius:     10px;
+  --pf-radius-lg:  16px;
+  --pf-shadow-sm:  0 1px 4px rgba(15,31,58,0.08);
+  --pf-shadow:     0 2px 12px rgba(15,31,58,0.10);
+  --pf-shadow-lg:  0 8px 32px rgba(15,31,58,0.12);
+}
+
+/* ── App shell ──────────────────────────────────────────────────────────────── */
+.pf-app        { display: flex; height: 100vh; overflow: hidden; font-family: 'Outfit', sans-serif; font-size: 14px; background: var(--pf-sky); color: var(--pf-ink); }
+.pf-main       { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
+.pf-content    { flex: 1; overflow-y: auto; overflow-x: hidden; }
+.pf-content::-webkit-scrollbar { width: 7px; }
+.pf-content::-webkit-scrollbar-thumb { background: var(--pf-rule); border-radius: 4px; }
+.pf-view-pad   { padding: 28px 32px; animation: pfFadeUp 0.25s ease; }
+@keyframes pfFadeUp { from { opacity:0; transform:translateY(6px) } to { opacity:1; transform:translateY(0) } }
+
+/* ── Sidebar ────────────────────────────────────────────────────────────────── */
+.pf-sidebar { width: 252px; min-width: 252px; background: var(--pf-white); border-right: 1px solid var(--pf-rule); display: flex; flex-direction: column; overflow: hidden; box-shadow: 2px 0 16px rgba(15,31,58,0.06); z-index: 20; }
+.pf-logo { padding: 20px 20px 16px; border-bottom: 1px solid var(--pf-rule-light); display: flex; align-items: center; gap: 10px; }
+.pf-logo-mark { width: 36px; height: 36px; border-radius: 9px; background: linear-gradient(135deg, var(--pf-cobalt), var(--pf-cobalt-mid)); display: flex; align-items: center; justify-content: center; font-size: 18px; box-shadow: 0 4px 12px rgba(23,86,200,0.25); }
+.pf-logo-text { font-family: 'Playfair Display', serif; font-size: 19px; font-weight: 700; color: var(--pf-ink); }
+.pf-logo-text em { font-style: normal; color: var(--pf-cobalt); }
+.pf-logo-sub { font-size: 10px; color: var(--pf-ink-dim); letter-spacing: 1.2px; text-transform: uppercase; font-family: 'JetBrains Mono', monospace; }
+.pf-course-switcher { background: var(--pf-sky); border: 1px solid var(--pf-rule); border-radius: var(--pf-radius); padding: 10px 12px; cursor: pointer; transition: all 0.2s; }
+.pf-course-switcher:hover { border-color: var(--pf-cobalt-mid); background: var(--pf-cobalt-lt); }
+.pf-cs-label { font-size: 9px; color: var(--pf-ink-dim); text-transform: uppercase; letter-spacing: 1.2px; font-family: 'JetBrains Mono', monospace; margin-bottom: 4px; }
+.pf-cs-row { display: flex; align-items: center; gap: 8px; }
+.pf-cs-badge { width: 22px; height: 22px; border-radius: 5px; display: flex; align-items: center; justify-content: center; font-size: 13px; }
+.pf-cs-name { font-weight: 600; font-size: 13px; flex: 1; }
+.pf-cs-chevron { color: var(--pf-ink-dim); font-size: 10px; }
+.pf-course-dropdown { position: absolute; top: calc(100% + 4px); left: 0; right: 0; background: var(--pf-white); border: 1px solid var(--pf-rule); border-radius: var(--pf-radius); box-shadow: var(--pf-shadow-lg); z-index: 100; overflow: hidden; }
+.pf-cd-item { display: flex; align-items: center; gap: 10px; padding: 11px 14px; cursor: pointer; transition: background 0.15s; border-bottom: 1px solid var(--pf-rule-light); }
+.pf-cd-item:hover { background: var(--pf-sky); }
+.pf-cd-item.active { background: var(--pf-cobalt-lt); }
+.pf-cd-info { flex: 1; }
+.pf-cd-name { font-size: 13px; font-weight: 600; }
+.pf-cd-sub  { font-size: 11px; color: var(--pf-ink-dim); }
+.pf-cd-check { color: var(--pf-cobalt); }
+.pf-cd-add { color: var(--pf-cobalt); font-size: 12px; font-weight: 600; display: flex; align-items: center; gap: 6px; padding: 11px 14px; border-top: 1px solid var(--pf-rule-light); cursor: pointer; }
+.pf-cd-add:hover { background: var(--pf-sky); }
+.pf-nav-scroll { flex: 1; overflow-y: auto; padding: 8px 10px; }
+.pf-nav-section-label { font-size: 9.5px; color: var(--pf-ink-dim); text-transform: uppercase; letter-spacing: 1.2px; font-family: 'JetBrains Mono', monospace; padding: 14px 8px 5px; font-weight: 500; }
+.pf-nav-item { display: flex; align-items: center; gap: 9px; padding: 8px 10px; border-radius: var(--pf-radius-sm); cursor: pointer; transition: all 0.15s; color: var(--pf-ink-mid); font-size: 13.5px; margin-bottom: 1px; }
+.pf-nav-item:hover { background: var(--pf-sky); color: var(--pf-ink); }
+.pf-nav-item.active { background: var(--pf-cobalt-lt); color: var(--pf-cobalt); font-weight: 600; }
+.pf-ni-icon  { font-size: 15px; width: 20px; text-align: center; flex-shrink: 0; }
+.pf-ni-badge { margin-left: auto; background: var(--pf-cobalt); color: #fff; font-size: 9px; font-weight: 700; padding: 1px 6px; border-radius: 10px; font-family: 'JetBrains Mono', monospace; }
+.pf-ni-count { margin-left: auto; background: var(--pf-sky-mid); color: var(--pf-ink-dim); font-size: 10px; font-weight: 600; padding: 1px 6px; border-radius: 10px; font-family: 'JetBrains Mono', monospace; }
+.pf-sidebar-footer { padding: 12px; border-top: 1px solid var(--pf-rule-light); }
+.pf-sf-prog-label { display: flex; justify-content: space-between; font-size: 11px; color: var(--pf-ink-dim); margin-bottom: 5px; }
+.pf-sf-prog-label strong { color: var(--pf-cobalt); font-family: 'JetBrains Mono', monospace; }
+.pf-sf-bar  { height: 5px; background: var(--pf-rule); border-radius: 3px; overflow: hidden; }
+.pf-sf-fill { height: 100%; background: linear-gradient(90deg, var(--pf-cobalt), var(--pf-cobalt-mid)); border-radius: 3px; transition: width 0.5s ease; }
+
+/* ── Topbar ──────────────────────────────────────────────────────────────────── */
+.pf-topbar { background: var(--pf-white); border-bottom: 1px solid var(--pf-rule); padding: 0 28px; height: 56px; display: flex; align-items: center; justify-content: space-between; box-shadow: var(--pf-shadow-sm); }
+.pf-topbar-left { display: flex; align-items: center; gap: 14px; }
+.pf-page-title { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; }
+.pf-breadcrumb { font-size: 12px; color: var(--pf-ink-dim); font-family: 'JetBrains Mono', monospace; }
+.pf-breadcrumb span { color: var(--pf-cobalt); }
+.pf-topbar-right { display: flex; align-items: center; gap: 10px; }
+.pf-search-wrap { display: flex; align-items: center; background: var(--pf-sky); border: 1.5px solid var(--pf-rule); border-radius: var(--pf-radius); padding: 6px 12px; gap: 7px; width: 220px; }
+.pf-search-wrap input { background: transparent; border: none; outline: none; font-size: 13px; color: var(--pf-ink); width: 100%; font-family: 'Outfit', sans-serif; }
+.pf-search-wrap input::placeholder { color: var(--pf-ink-dim); }
+.pf-search-icon { color: var(--pf-ink-dim); font-size: 13px; }
